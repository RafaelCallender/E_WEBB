@page
@model E_WEBB.Pages.Contact_UseModel
@{

    Layout = null;

}

<link href="~/css/site02.css" rel="stylesheet" />

<link href="~/css/site04.css" rel="stylesheet" />
<div class="comic-bg">

    <h1>CONTACT THE TECH HEROES!</h1>

    <div class="contact-container">

        <!-- Email Form -->
        <div class="contact-card">
            <h2>📧 SEND US A MESSAGE!</h2>

            <form method="post">
                <label>Your Name</label>
                <input type="text" name="Name" asp-for="Contact_Us_M01.Name" required />
                <div class="status-label">

                    @Model.Contact_Us_M01.StatusMessage
                </div>
                <label>Email</label>
                <input type="email" name="Email" asp-for="Contact_Us_M01.Email" required />
                <div class="status-label">

                    @Model.Contact_Us_M01.StatusMessage01
                </div>
                <label>Phonenumber</label>
                <input type="text" name="Phonenumber" asp-for="Contact_Us_M01.phonenumber" required />
                <div class="status-label">

                    @Model.Contact_Us_M01.StatusMessage01
                </div>
                <label>Your Message</label>
                <textarea name="Message" asp-for="Contact_Us_M01.Message" required></textarea>
                <div class="status-label">

                    @Model.Contact_Us_M01.StatusMessage02
                </div>
                <button type="submit" asp-page-handler="SendEmail" class="send-btn">
                    🚀 SEND MESSAGE
                </button>
            </form>
        </div>
        <div class="status-label">

            @Model.Contact_Us_M01.StatusMessage03
        </div>
        <!-- Call Section -->
        <div class="call-box">
            📞 CALL NOW: @Model.Contact_Us_M01.client_phonenumber
            <br />
            💥 ONLY $25 PER REMOTE SESSION!
        </div>
        <!-- 💸 Payment Section -->
        <div class="payment-card marval-style">
            <h2>💸 PAY SECURELY!</h2>

            <p class="pay-text">
                Fast. Easy. Secure. <br />
                Choose your preferred method to send $25 🚀
            </p>
           <div class="payment-grid">

    <!-- Cash App -->
    <div class="pay-item">
        <a href="@Model.Contact_Us_M01.data05" target="_blank" class="payment-btn cashapp-btn">
            <img src="@Url.Content(Model.Contact_Us_M01.data02)" class="payment-logo" />
            <span>Cash App</span>
        </a>
        <img src="@Url.Content(Model.Contact_Us_M01.data03)" class="qr-code" />
    </div>

    <!-- Zelle -->
    <div class="pay-item">
        <a href="@Model.Contact_Us_M01.data03" target="_blank" class="payment-btn zelle-btn">
            <img src="@Url.Content(Model.Contact_Us_M01.data04)" class="payment-logo" />
            <span>Zelle</span>
        </a>
        <img src="@Url.Content(Model.Contact_Us_M01.data05)" class="qr-code" />
    </div>

    <!-- PayPal -->
    <div class="pay-item">
        <a href="@Model.Contact_Us_M01.data06" target="_blank" class="payment-btn paypal-btn">
            <img src="@Url.Content(Model.Contact_Us_M01.data07)" class="payment-logo" />
            <span>PayPal</span>
        </a>
        <img src="@Url.Content(Model.Contact_Us_M01.data08)" class="qr-code" />
    </div>

    <!-- Venmo -->
    <div class="pay-item">
        <a href="@Model.Contact_Us_M01.data09" target="_blank" class="payment-btn venmo-btn">
            <img src="@Url.Content(Model.Contact_Us_M01.data09)" class="payment-logo" />
            <span>Venmo</span>
        </a>
        <img src="@Url.Content(Model.Contact_Us_M01.data10)" class="qr-code" />
    </div>

</div>

                <p class="scan-text">Scan QR to Pay $25</p>
            </div>




            <p class="note-text">
                Your payment is processed securely. No sensitive info stored here.
            </p>
        </div>
        <div class="cta">   
            <form method="post">
                <button type="submit" asp-page-handler="Back" class="send-btn">
                    ⚡ Back ⚡
                </button>
            </form>
        
    <footer>
        © 2026 EASY CALLENDER — We Answer the Call!
    </footer>
		</div>
    </div>
</div>